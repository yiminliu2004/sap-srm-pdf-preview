{
  "manifest_version": 3,
  "name": "SAP SRM PDF Preview",
  "version": "8.0",
  "description": "Previews SAP document files (PDF and images) in a side panel instead of downloading them. No tab flash.",
  "permissions": ["sidePanel", "offscreen", "scripting", "storage", "downloads"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SAP PDF Preview"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
